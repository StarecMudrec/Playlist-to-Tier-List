# Spotify — два способа (достаточно одного):

# Способ 1: sp_dc cookie из браузера (проще, не нужна регистрация)
# Открой Spotify в браузере → F12 → Application → Cookies → open.spotify.com → sp_dc
SPOTIFY_DC_COOKIE=your_sp_dc_cookie_here

# Способ 2: OAuth (рекомендуется) — логин через браузер, работает с VPS
# Redirect URI должен совпадать с тем что указан в Spotify Dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://your-domain-or-ip/spotify/callback

# Yandex Music token (optional — users can also paste it in the UI)
# Obtain via: https://github.com/MarshalX/yandex-music-token (browser extension)
YM_TOKEN=your_ym_token_here

# Flask config
PORT=5000
FLASK_DEBUG=0
